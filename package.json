{
  "name": "@worthy/shared",
  "version": "0.1.0",
  "description": "Shared types, scoring engine, constants, and validation for Worthy platform",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepare": "npm run build",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:scoring": "vitest run src/scoring",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "db:gen-types": "supabase gen types typescript --project-id enophqzovmvhhwtfddnm > src/types/database.generated.ts",
    "db:gen-types:local": "supabase gen types typescript --local > src/types/database.generated.ts",
    "db:reset": "supabase db reset",
    "db:push": "supabase db push",
    "db:migrate:new": "supabase migration new"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0",
    "eslint": "^9.20.0",
    "@eslint/js": "^9.20.0",
    "typescript-eslint": "^8.25.0",
    "prettier": "^3.5.0",
    "supabase": "^2.20.0"
  },
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": ">=18"
  }
}
